[global]
    follow = keyboard
    width = (0, 350)
    height = (0, 300)
    origin = top-right
    offset = (10, 34)
    
    notification_limit = 5
    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    progress_bar_corner_radius = 0
    
    indicate_hidden = yes
    separator_height = 1
    separator_color = frame
    padding = 10
    horizontal_padding = 10
    text_icon_padding = 0
    frame_width = 2
    gap_size = 6
    corner_radius = 4
    
    sort = yes
    idle_threshold = 120
    
    font = JetBrainsMono Nerd Font Mono 9
    line_height = 2
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    
    show_age_threshold = 60
    word_wrap = yes
    ellipsize = middle
    ignore_newline = no
    
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes
    
    enable_recursive_icon_lookup = false
    icon_position = off
    min_icon_size = 0
    max_icon_size = 0
    
    sticky_history = yes
    history_length = 50
    
    browser = /usr/bin/xdg-open
    dmenu = /usr/bin/rofi -dmenu -p action
    
    mouse_left_click = do_action, close_current
    mouse_middle_click = close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#0b0b0d"
    foreground = "#ff73c9"
    frame_color = "#ff73c9"
    timeout = 5

[urgency_normal]
    background = "#0b0b0d"
    foreground = "#ff73c9"
    frame_color = "#ff2b9e"
    timeout = 10

[urgency_critical]
    background = "#0b0b0d"
    foreground = "#ff2b9e"
    frame_color = "#ff2b9e"
    timeout = 0

[keyboard_layout]
    summary = "Layout:*"
    skip_display = false
    history_ignore = yes
    timeout = 2
