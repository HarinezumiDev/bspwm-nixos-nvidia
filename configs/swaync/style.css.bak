* {
  font-family: "JetBrainsMono Nerd Font", "Font Awesome 6 Free";
  font-size: 14px;
  font-weight: 500;
}

.blank-window {
  background: rgba(0, 0, 0, 0.3);
}

.control-center {
  background: rgba(20, 8, 8, 0.98);
  border: 2px solid rgba(100, 30, 30, 0.6);
  border-radius: 20px;
  color: #ffdd88;
  padding: 16px;
  margin: 0;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6);
}

.control-center .widget-mpris {
  background: transparent;
  border: none;
  margin: 0px 0px 16px 0px;
  padding: 0;
  color: #ffdd88;
}

.control-center .widget-mpris > box {
  background: transparent;
}

.control-center .widget-mpris-player {
  background: transparent;
  padding: 0;
}

.control-center .widget-mpris-album-art {
  border-radius: 12px;
  margin-bottom: 12px;
  /*margin: 0 0 12px 0;*/
}

.control-center .widget-mpris-title {
  font-size: 16px;
  font-weight: 700;
  color: #ffe680;
  margin-bottom: 4px;
}

.control-center .widget-mpris-subtitle {
  font-size: 13px;
  color: #ffcc88;
  opacity: 0.9;
  margin-bottom: 12px;
}

.control-center .widget-mpris-player button {
  background: rgba(80, 25, 25, 0.6);
  border: 1px solid rgba(120, 40, 40, 0.5);
  border-radius: 10px;
  color: #ffdd88;
  min-width: 44px;
  min-height: 44px;
  margin: 0 4px;
  transition: all 0.3s cubic-bezier(0.4, 0.0, 0.2, 1);
}

.control-center .widget-mpris-player button:hover {
  background: rgba(100, 35, 35, 0.8);
  border-color: rgba(150, 50, 50, 0.7);
  box-shadow: 0 4px 12px rgba(255, 100, 100, 0.3);
}

.control-center .widget-mpris-player button:active {
}

separator {
  background: rgba(120, 40, 40, 0.3);
  min-height: 1px;
  margin: 16px 0;
}

.control-center .notification-list {
  background: transparent;
  padding: 0;
}

.notification {
  background: rgba(40, 15, 15, 1);
  border: 1px solid rgba(120, 40, 40, 0.5);
  border-radius: 14px;
  margin: 8px 0;
  padding: 14px;
  color: #ffdd88;
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.4);
  transition: all 0.3s cubic-bezier(0.4, 0.0, 0.2, 1);
}

.notification:hover {
  background: rgba(50, 18, 18, 0.95);
  border-color: rgba(150, 50, 50, 0.6);
  box-shadow: 0 6px 20px rgba(255, 100, 100, 0.2);
}

.notification-content {
  padding: 4px;
}

.notification .notification-default-action {
  background: transparent;
  padding: 4px;
}

.notification .notification-default-action:hover {
  background: rgba(60, 20, 20, 0.5);
  border-radius: 10px;
}

.summary {
  font-size: 15px;
  font-weight: 700;
  color: #ffe680;
  margin-bottom: 4px;
}

.body {
  font-size: 13px;
  color: #ffcc99;
  opacity: 0.95;
}

.notification-time {
  font-size: 11px;
  color: #ff9999;
  opacity: 0.7;
  margin-top: 6px;
}

.close-button {
  background: rgba(150, 40, 40, 0.7);
  border: 1px solid rgba(180, 50, 50, 0.6);
  border-radius: 10px;
  color: #ffcccc;
  min-width: 24px;
  min-height: 24px;
  margin: 4px;
  transition: all 0.3s cubic-bezier(0.4, 0.0, 0.2, 1);
}

.close-button:hover {
  background: rgba(180, 50, 50, 0.9);
  border-color: rgba(200, 60, 60, 0.8);
  box-shadow: 0 4px 12px rgba(255, 100, 100, 0.4);
}

.close-button:active {
}

.notification-icon {
  border-radius: 12px;
  margin-right: 12px;
}

.notification-action {
  background: rgba(80, 25, 25, 0.6);
  border: 1px solid rgba(120, 40, 40, 0.5);
  border-radius: 10px;
  color: #ffdd88;
  padding: 8px 14px;
  margin: 4px 4px 4px 0;
  transition: all 0.3s cubic-bezier(0.4, 0.0, 0.2, 1);
}

.notification-action:hover {
  background: rgba(100, 35, 35, 0.8);
  border-color: rgba(150, 50, 50, 0.7);
  box-shadow: 0 4px 10px rgba(255, 100, 100, 0.3);
}

.notification-action:active {
}

@keyframes slide-in {
  from {
    opacity: 0;
    margin-top: -20px;
  }
  to {
    opacity: 1;
    margin-top: 0;
  }
}

.control-center {
  animation: slide-in 0.3s cubic-bezier(0.4, 0.0, 0.2, 1);
}

scrollbar {
  background: rgba(20, 8, 8, 0.3);
  border-radius: 10px;
}

scrollbar slider {
  background: rgba(150, 50, 50, 0.6);
  border-radius: 10px;
  min-height: 40px;
  min-width: 8px;
  transition: all 0.3s ease;
}

scrollbar slider:hover {
  background: rgba(180, 60, 60, 0.8);
}
